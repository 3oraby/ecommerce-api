doctype html
html
  head
    meta(charset="UTF-8")
    style.
      body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
      .container { max-width: 600px; margin: 0 auto; padding: 20px; border: 1px solid #ddd; border-radius: 5px; text-align: center; }
      .btn { display: inline-block; padding: 10px 20px; margin: 20px 0; background-color: #dc3545; color: #fff; text-decoration: none; border-radius: 5px; }
      .security-note { margin-top: 20px; padding: 10px; background-color: #f8d7da; color: #721c24; border-radius: 5px; font-size: 14px; }
  body
    div.container
      h2 Hello #{name},
      p You recently requested to reset your password. Click the button below to proceed:
      a.btn(href=resetUrl) Reset Password
      p If the button doesn't work, copy and paste this link into your browser:
      p #{resetUrl}
      div.security-note
        p Security Note: If you did not request a password reset, you can safely ignore this email. Your password will remain unchanged.
