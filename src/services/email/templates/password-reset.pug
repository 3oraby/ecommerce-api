doctype html
html
  head
    meta(charset="UTF-8")
    style.
      body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
      .container { max-width: 600px; margin: 0 auto; padding: 20px; border: 1px solid #ddd; border-radius: 5px; text-align: center; }
      .otp-box { display: inline-block; padding: 15px 30px; margin: 20px 0; background-color: #f4f4f4; color: #333; font-size: 24px; font-weight: bold; letter-spacing: 2px; border-radius: 5px; border: 1px dashed #ccc; }
      .security-note { margin-top: 20px; padding: 10px; background-color: #f8d7da; color: #721c24; border-radius: 5px; font-size: 14px; }
      .footer { margin-top: 20px; font-size: 12px; color: #777; }
  body
    div.container
      h2 Hello #{name},
      p We received a request to reset your password. Use the following OTP to proceed:
      div.otp-box #{otp}
      p This code will expire at #{expiresAt}. Please do not share it with anyone.
      div.security-note
        p Security Note: If you did not request a password reset, you can safely ignore this email. Your password will remain unchanged.
